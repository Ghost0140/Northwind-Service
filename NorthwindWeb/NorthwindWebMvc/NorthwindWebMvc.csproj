<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Grpc.AspNetCore" Version="2.49.0" />
		<PackageReference Include="Microsoft.VisualStudio.Web.CodeGeneration.Design" Version="8.0.22" />
		<PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
	</ItemGroup>

	<ItemGroup>
	  <Protobuf Include="..\NorthwindgRPC\Protos\orden.proto" GrpcServices="Client">
	    <Link>Protos\orden.proto</Link>
	  </Protobuf>
	  <Protobuf Include="..\NorthwindgRPC\Protos\productos.proto" GrpcServices="Client">
	    <Link>Protos\productos.proto</Link>
	  </Protobuf>
	</ItemGroup>
</Project>
