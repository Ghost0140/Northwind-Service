@model NorthwindWebMvc.Models.StoreViewModels.CartViewModel

@{
    ViewData["Title"] = "Carrito de Compras";
}

<div class="store-page">
    <div class="container">
        <div class="store-hero d-flex justify-content-between align-items-center flex-wrap gap-3">
            <h1 class="h3 mb-0">Carrito de Compras</h1>
            <a asp-action="Catalog" class="btn btn-light">
                <i class="bi bi-arrow-left"></i> Seguir Comprando
            </a>
        </div>

        @if (TempData["mensaje"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-1"></i> @TempData["mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (Model.Items == null || Model.Items.Count == 0)
        {
            <div class="alert alert-info text-center py-5">
                <h4>Tu carrito está vacío</h4>
                <p class="mb-3">No hay productos en tu carrito</p>
                <a asp-action="Catalog" class="btn btn-primary">
                    <i class="bi bi-shop"></i> Ir al Catálogo
                </a>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-md-8">
                    <div class="card store-soft-card">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 store-table">
                                <thead class="table-light">
                                    <tr>
                                        <th>Producto</th>
                                        <th class="text-end">Precio</th>
                                        <th class="text-center">Cantidad</th>
                                        <th class="text-end">Subtotal</th>
                                        <th class="text-center">Acción</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                <tr>
                                    <td>
                                        <a asp-action="ProductDetail" asp-route-id="@item.ProductID" class="text-decoration-none">
                                            @item.ProductName
                                        </a>
                                    </td>
                                    <td class="text-end">$@item.UnitPrice.ToString("F2")</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end fw-bold">$@item.SubTotal.ToString("F2")</td>
                                    <td class="text-center">
                                        <form asp-action="RemoveFromCart" method="post" style="display:inline;">
                                            <input type="hidden" name="productID" value="@item.ProductID" />
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card store-soft-card store-sticky mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Resumen del Pedido</h5>
                            <hr />
                            <div class="d-flex justify-content-between mb-2">
                                <span>Productos:</span>
                                <span>@Model.ItemCount</span>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <span>Subtotal:</span>
                                <span>$@Model.Total.ToString("F2")</span>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between mb-3 h5">
                                <span>Total:</span>
                                <span class="text-success">$@Model.Total.ToString("F2")</span>
                            </div>
                            <a asp-action="Checkout" class="btn btn-success w-100 mb-2">
                                <i class="bi bi-credit-card"></i> Proceder al Pago
                            </a>
                            <form asp-action="ClearCart" method="post" style="display:inline; width:100%;">
                                <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('¿Vaciar carrito?')">
                                    <i class="bi bi-trash"></i> Vaciar Carrito
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
