@model NorthwindWebMvc.Models.StoreViewModels.OrderViewModel

@{
    ViewData["Title"] = $"Pedido #{Model.OrderID}";
}

<div class="store-page">
<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <a asp-action="MyOrders" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Volver a Mis Compras
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card store-soft-card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Información del Pedido</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Número de Pedido:</strong></p>
                            <h4 class="text-primary mb-3">#@Model.OrderID</h4>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Fecha del Pedido:</strong></p>
                            <p class="mb-3">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle"></i> Pedido Confirmado
                    </div>
                </div>
            </div>

            <div class="card store-soft-card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Productos</h5>
                </div>
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th class="text-end">Precio Unitario</th>
                            <th class="text-center">Cantidad</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td class="text-end">$@item.UnitPrice.ToString("F2")</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end fw-bold">$@item.SubTotal.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card store-soft-card store-sticky">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Resumen</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <p class="text-muted mb-1">Cantidad de Productos:</p>
                        <p class="h6">@Model.Items.Count</p>
                    </div>
                    <div class="mb-3">
                        <p class="text-muted mb-1">Unidades Totales:</p>
                        <p class="h6">@Model.Items.Sum(x => x.Quantity)</p>
                    </div>
                    <hr />
                    <div>
                        <p class="text-muted mb-1">Total del Pedido:</p>
                        <h4 class="text-success">$@Model.Total.ToString("F2")</h4>
                    </div>
                </div>
            </div>

            <div class="card store-soft-card mt-3">
                <div class="card-body">
                    <div class="d-flex gap-2">
                        <a asp-action="Catalog" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-shop"></i> Seguir Comprando
                        </a>
                        <a asp-action="MyOrders" class="btn btn-outline-secondary flex-grow-1">
                            <i class="bi bi-list"></i> Mis Pedidos
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
