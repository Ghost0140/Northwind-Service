@model NorthwindWebMvc.Models.StoreViewModels.CatalogViewModel

@{
    ViewData["Title"] = "Catálogo de Productos";
}

<div class="store-page">
    <div class="container">
        <div class="store-hero d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div>
                <h1 class="h3 mb-1">Catálogo de Productos</h1>
                <p class="mb-0 opacity-75">Explora, filtra y agrega productos al carrito.</p>
            </div>
            <a asp-action="Cart" class="btn btn-light">
                <i class="bi bi-cart"></i> Ver Carrito
            </a>
        </div>

        @if (TempData["mensaje"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-1"></i> @TempData["mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="store-toolbar">
            <div class="row g-3">
                <div class="col-md-4">
                    <form method="get">
                        <label for="categoryID" class="form-label">Filtrar por Categoría</label>
                        <select id="categoryID" name="categoryID" class="form-select" onchange="this.form.submit()">
                            <option value="">Todas las categorías</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.CategoryID" selected="@(Model.SelectedCategoryID == category.CategoryID)">
                                    @category.CategoryName
                                </option>
                            }
                        </select>
                    </form>
                </div>
                <div class="col-md-8">
                    <form method="get">
                        <div class="input-group">
                            <input type="text" name="search" class="form-control" placeholder="Buscar productos..." value="@Model.SearchTerm">
                            <button class="btn btn-primary" type="submit">
                                <i class="bi bi-search"></i> Buscar
                            </button>
                            @if (!string.IsNullOrEmpty(Model.SearchTerm))
                            {
                                <a href="@Url.Action("Catalog")" class="btn btn-outline-secondary">
                                    <i class="bi bi-x"></i> Limpiar
                                </a>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @if (Model.Products == null || Model.Products.Count == 0)
        {
            <div class="alert alert-info text-center py-4">No hay productos disponibles</div>
        }
        else
        {
            <div class="row">
                @foreach (var product in Model.Products)
                {
                    <div class="col-md-6 col-xl-4 mb-4">
                        <div class="card store-card h-100 shadow-sm">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title mb-1">@product.ProductName</h5>
                                    @if (!string.IsNullOrEmpty(product.CategoryName))
                                    {
                                        <span class="badge text-bg-light">@product.CategoryName</span>
                                    }
                                </div>
                                <p class="text-muted mb-4">Stock: <strong>@product.UnitsInStock</strong> unidades</p>
                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <span class="store-price">$@product.UnitPrice?.ToString("F2")</span>
                                    @if (product.UnitsInStock > 0)
                                    {
                                        <a asp-action="ProductDetail" asp-route-id="@product.ProductID" class="btn btn-sm btn-primary">
                                            <i class="bi bi-eye"></i> Ver detalle
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-danger">Agotado</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Paginación del catálogo" class="mt-3">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Catalog"
                               asp-route-categoryID="@Model.SelectedCategoryID"
                               asp-route-search="@Model.SearchTerm"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-pageSize="@Model.PageSize">Anterior</a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Catalog"
                                   asp-route-categoryID="@Model.SelectedCategoryID"
                                   asp-route-search="@Model.SearchTerm"
                                   asp-route-page="@i"
                                   asp-route-pageSize="@Model.PageSize">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Catalog"
                               asp-route-categoryID="@Model.SelectedCategoryID"
                               asp-route-search="@Model.SearchTerm"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-pageSize="@Model.PageSize">Siguiente</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>
