@model NorthwindWebMvc.Models.StoreViewModels.OrderViewModel

@{
    ViewData["Title"] = "Pedido Confirmado";
}

<div class="store-page">
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card store-soft-card text-center mb-4">
                <div class="card-body py-5">
                    <div class="mb-4">
                        <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
                    </div>
                    <h1 class="card-title text-success mb-3">¡Pedido Confirmado!</h1>
                    <p class="lead mb-4">Tu pedido ha sido procesado correctamente</p>
                </div>
            </div>

            <div class="card store-soft-card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Detalles del Pedido</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p><strong>Número de Pedido:</strong></p>
                            <h4 class="text-primary">#@Model.OrderID</h4>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Fecha:</strong></p>
                            <p>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card store-soft-card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Productos</h5>
                </div>
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th class="text-end">Precio</th>
                            <th class="text-center">Cantidad</th>
                            <th class="text-end">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td class="text-end">$@item.UnitPrice.ToString("F2")</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">$@item.SubTotal.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="card store-soft-card mb-4">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <h5>Total del Pedido</h5>
                        </div>
                        <div class="col-md-4 text-end">
                            <h4 class="text-success">$@Model.Total.ToString("F2")</h4>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle"></i> Recibirás un correo de confirmación pronto con más detalles sobre tu pedido.
            </div>

            <div class="d-flex gap-2">
                <a asp-action="MyOrders" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-list-check"></i> Ver Mis Pedidos
                </a>
                <a asp-action="Catalog" class="btn btn-outline-secondary flex-grow-1">
                    <i class="bi bi-shop"></i> Seguir Comprando
                </a>
            </div>
        </div>
    </div>
</div>
</div>
