@model List<NorthwindWebMvc.Models.StoreViewModels.OrderViewModel>

@{
    ViewData["Title"] = "Mis Compras";
}

<div class="store-page">
    <div class="container">
        <div class="store-hero d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h1 class="h3 mb-0">Mis Compras</h1>
            <a asp-action="Catalog" class="btn btn-light">
                <i class="bi bi-shop"></i> Ir al Catálogo
            </a>
        </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info text-center py-5">
            <h4>No tienes pedidos</h4>
            <p class="mb-3">Aún no has realizado ninguna compra</p>
            <a asp-action="Catalog" class="btn btn-primary">
                <i class="bi bi-shop"></i> Explorar Productos
            </a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var order in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card store-card h-100 shadow-sm">
                        <div class="card-header bg-light">
                            <div class="row align-items-center">
                                <div class="col">
                                    <h5 class="mb-0">Pedido #@order.OrderID</h5>
                                </div>
                                <div class="col-auto">
                                    <span class="badge bg-success">Confirmado</span>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <p class="mb-1"><strong>Fecha:</strong></p>
                                <p>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                            <div class="mb-3">
                                <p class="mb-1"><strong>Cantidad de Productos:</strong></p>
                                <p>@order.Items.Count</p>
                            </div>
                            <div class="mb-3">
                                <p class="mb-1"><strong>Total:</strong></p>
                                <h5 class="text-success">$@order.Total.ToString("F2")</h5>
                            </div>
                            <a asp-action="OrderDetails" asp-route-orderID="@order.OrderID" class="btn btn-primary w-100">
                                <i class="bi bi-eye"></i> Ver Detalles
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    </div>
</div>
