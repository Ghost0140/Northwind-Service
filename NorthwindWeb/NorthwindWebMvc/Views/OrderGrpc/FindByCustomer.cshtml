@model NorthwindWebMvc.Models.PagedList<NorthwindWebMvc.Models.Order>

@{
    ViewData["Title"] = "Pedidos por Cliente";
}

<div class="crud-page">
    <div class="container">
        <div class="card crud-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="bi bi-receipt"></i> Pedidos por Cliente
                </h4>

                <div class="d-flex gap-2">
                    <a asp-controller="Home" asp-action="Index"
                       class="btn btn-outline-light btn-sm btn-action">
                        <i class="bi bi-house"></i> Inicio
                    </a>
                </div>
            </div>

            <!-- FILTRO -->
            <form asp-action="FindByCustomer" method="get" class="crud-filter row g-2 mb-2">
                <div class="col-md-4">
                    <input type="text"
                           name="customerID"
                           value="@ViewBag.CustomerID"
                           class="form-control"
                           placeholder="Ingrese el ID del cliente"
                           maxlength="5"
                           required />
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Consultar
                    </button>
                </div>

                <div class="col-md-2">
                    <a asp-action="FindByCustomer" class="btn btn-secondary w-100">
                        Limpiar
                    </a>
                </div>
            </form>

            <!-- RESULTADOS -->
            <div class="card-body bg-white">
                <div class="d-flex justify-content-end mb-2 crud-total">
                    <span class="text-muted fw-semibold">
                        Total de registros mostrados: @Model.TotalItems
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center crud-table">
                        <thead>
                            <tr>
                                <th>@Html.DisplayNameFor(m => m.Items.First().OrderID)</th>
                                <th>@Html.DisplayNameFor(m => m.Items.First().CompanyName)</th>
                                <th>@Html.DisplayNameFor(m => m.Items.First().OrderDate)</th>
                                <th>@Html.DisplayNameFor(m => m.Items.First().RequiredDate)</th>
                                <th>@Html.DisplayNameFor(m => m.Items.First().ShippedDate)</th>
                                <th>@Html.DisplayNameFor(m => m.Items.First().ShipCountry)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Items.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-muted py-3">
                                        No hay pedidos para mostrar.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>@item.OrderID</td>
                                        <td>@item.CompanyName</td>
                                        <td>@item.OrderDateDisplay</td>
                                        <td>@item.RequiredDateDisplay</td>
                                        <td>@item.ShippedDateDisplay</td>
                                        <td>@item.ShipCountryDisplay</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <nav aria-label="Page navigation" class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="FindByCustomer" asp-route-page="@(Model.PageNumber - 1)" asp-route-customerID="@ViewBag.CustomerID">Anterior</a>
                    </li>

                    @{
                        int start = Math.Max(1, Model.PageNumber - 3);
                        int end = Math.Min(Model.TotalPages, Model.PageNumber + 3);
                        if (start > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="FindByCustomer" asp-route-page="1" asp-route-customerID="@ViewBag.CustomerID">1</a>
                            </li>
                            if (start > 2)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                        }

                        for (int i = start; i <= end; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" asp-action="FindByCustomer" asp-route-page="@i" asp-route-customerID="@ViewBag.CustomerID">@i</a>
                            </li>
                        }

                        if (end < Model.TotalPages)
                        {
                            if (end < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                            <li class="page-item">
                                <a class="page-link" asp-action="FindByCustomer" asp-route-page="@Model.TotalPages" asp-route-customerID="@ViewBag.CustomerID">@Model.TotalPages</a>
                            </li>
                        }
                    }

                    <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="FindByCustomer" asp-route-page="@(Model.PageNumber + 1)" asp-route-customerID="@ViewBag.CustomerID">Siguiente</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>


