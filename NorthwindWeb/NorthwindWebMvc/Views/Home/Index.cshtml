@model NorthwindWebMvc.Models.Home

@{
    ViewData["Title"] = "Dashboard Admin";
    var totalGeneral = Model.TotalProductos + Model.TotalClientes + Model.TotalTransportistas + Model.TotalProveedores;
}

<div class="dashboard-page">
    <div class="container py-4">
        <section class="dashboard-hero mb-4">
            <div>
                <h1 class="h3 mb-1">Dashboard Administrativo</h1>
                <p class="mb-0 text-light-emphasis">Visión general de entidades clave del sistema Northwind.</p>
            </div>
            <div class="text-md-end">
                <p class="mb-1 small text-uppercase fw-semibold text-light-emphasis">Total Registros</p>
                <h2 class="mb-0">@totalGeneral</h2>
            </div>
        </section>

        <section class="row g-3 mb-4">
            <div class="col-md-6 col-xl-3">
                <article class="kpi-card h-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="kpi-title">Productos</p>
                            <h3 class="counter mb-1">@Model.TotalProductos</h3>
                        </div>
                        <i class="bi bi-box-seam fs-4 text-primary"></i>
                    </div>
                    <p class="kpi-sub mb-0">Participación: <strong id="pctProductos">0%</strong></p>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="kpi-card h-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="kpi-title">Clientes</p>
                            <h3 class="counter mb-1">@Model.TotalClientes</h3>
                        </div>
                        <i class="bi bi-people fs-4 text-info"></i>
                    </div>
                    <p class="kpi-sub mb-0">Participación: <strong id="pctClientes">0%</strong></p>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="kpi-card h-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="kpi-title">Transportistas</p>
                            <h3 class="counter mb-1">@Model.TotalTransportistas</h3>
                        </div>
                        <i class="bi bi-truck fs-4 text-success"></i>
                    </div>
                    <p class="kpi-sub mb-0">Participación: <strong id="pctTransportistas">0%</strong></p>
                </article>
            </div>
            <div class="col-md-6 col-xl-3">
                <article class="kpi-card h-100">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="kpi-title">Proveedores</p>
                            <h3 class="counter mb-1">@Model.TotalProveedores</h3>
                        </div>
                        <i class="bi bi-building fs-4 text-secondary"></i>
                    </div>
                    <p class="kpi-sub mb-0">Participación: <strong id="pctProveedores">0%</strong></p>
                </article>
            </div>
        </section>

        <section class="row g-4 mb-4">
            <div class="col-lg-6">
                <div class="dashboard-card p-3 p-md-4 h-100">
                    <h5 class="mb-3">Distribución General</h5>
                    <div class="chart-container">
                        <canvas id="graficoDona"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="dashboard-card p-3 p-md-4 h-100">
                    <h5 class="mb-3">Comparativo por Entidad</h5>
                    <div class="chart-container">
                        <canvas id="graficoBarras"></canvas>
                    </div>
                </div>
            </div>
        </section>

        <section class="row g-4 mb-4">
            <div class="col-lg-6">
                <div class="dashboard-card p-3 p-md-4 h-100">
                    <h5 class="mb-3">Radar de Cobertura</h5>
                    <div class="chart-container">
                        <canvas id="graficoRadar"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="dashboard-card p-3 p-md-4 h-100">
                    <h5 class="mb-3">Peso Relativo</h5>
                    <div class="chart-container">
                        <canvas id="graficoPolar"></canvas>
                    </div>
                </div>
            </div>
        </section>

        <section class="row g-4">
            <div class="col-lg-7">
                <div class="dashboard-card p-3 p-md-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Resumen Ejecutivo</h5>
                        <span class="badge text-bg-primary">Actual</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Entidad</th>
                                    <th class="text-end">Total</th>
                                    <th class="text-end">Participación</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Productos</td>
                                    <td class="text-end">@Model.TotalProductos</td>
                                    <td class="text-end" id="rowPctProductos">0%</td>
                                </tr>
                                <tr>
                                    <td>Clientes</td>
                                    <td class="text-end">@Model.TotalClientes</td>
                                    <td class="text-end" id="rowPctClientes">0%</td>
                                </tr>
                                <tr>
                                    <td>Transportistas</td>
                                    <td class="text-end">@Model.TotalTransportistas</td>
                                    <td class="text-end" id="rowPctTransportistas">0%</td>
                                </tr>
                                <tr>
                                    <td>Proveedores</td>
                                    <td class="text-end">@Model.TotalProveedores</td>
                                    <td class="text-end" id="rowPctProveedores">0%</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="dashboard-card p-3 p-md-4 h-100">
                    <h5 class="mb-3">Accesos Rápidos</h5>
                    <div class="d-grid gap-2">
                        <a class="btn btn-outline-primary" asp-controller="Product" asp-action="Index"><i class="bi bi-box-seam me-2"></i>Administrar Productos</a>
                        <a class="btn btn-outline-primary" asp-controller="Customer" asp-action="Index"><i class="bi bi-people me-2"></i>Administrar Clientes</a>
                        <a class="btn btn-outline-primary" asp-controller="Supplier" asp-action="Index"><i class="bi bi-building me-2"></i>Administrar Proveedores</a>
                        <a class="btn btn-outline-primary" asp-controller="Shipper" asp-action="Index"><i class="bi bi-truck me-2"></i>Administrar Transportistas</a>
                        <a class="btn btn-outline-primary" asp-controller="Usuario" asp-action="Index"><i class="bi bi-person-gear me-2"></i>Gestión de Usuarios</a>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const labels = ['Productos', 'Clientes', 'Transportistas', 'Proveedores'];
    const valores = [@Model.TotalProductos, @Model.TotalClientes, @Model.TotalTransportistas, @Model.TotalProveedores];
    const total = valores.reduce((acc, value) => acc + value, 0);
    const colores = ['#2563eb', '#0ea5e9', '#16a34a', '#64748b'];

    function porcentaje(valor) {
        if (total === 0) return '0.0%';
        return `${((valor * 100) / total).toFixed(1)}%`;
    }

    document.getElementById('pctProductos').textContent = porcentaje(valores[0]);
    document.getElementById('pctClientes').textContent = porcentaje(valores[1]);
    document.getElementById('pctTransportistas').textContent = porcentaje(valores[2]);
    document.getElementById('pctProveedores').textContent = porcentaje(valores[3]);
    document.getElementById('rowPctProductos').textContent = porcentaje(valores[0]);
    document.getElementById('rowPctClientes').textContent = porcentaje(valores[1]);
    document.getElementById('rowPctTransportistas').textContent = porcentaje(valores[2]);
    document.getElementById('rowPctProveedores').textContent = porcentaje(valores[3]);

    document.querySelectorAll('.counter').forEach(counter => {
        const target = Number(counter.innerText);
        let current = 0;
        const step = Math.max(1, Math.ceil(target / 40));
        counter.innerText = '0';

        const tick = () => {
            current += step;
            if (current < target) {
                counter.innerText = String(current);
                requestAnimationFrame(tick);
            } else {
                counter.innerText = String(target);
            }
        };
        tick();
    });

    const commonOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom' } }
    };

    new Chart(document.getElementById('graficoDona'), {
        type: 'doughnut',
        data: { labels, datasets: [{ data: valores, backgroundColor: colores, borderWidth: 0 }] },
        options: commonOptions
    });

    new Chart(document.getElementById('graficoBarras'), {
        type: 'bar',
        data: { labels, datasets: [{ data: valores, backgroundColor: colores, borderRadius: 8 }] },
        options: {
            ...commonOptions,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true } }
        }
    });

    new Chart(document.getElementById('graficoRadar'), {
        type: 'radar',
        data: {
            labels,
            datasets: [{
                label: 'Cobertura',
                data: valores,
                fill: true,
                backgroundColor: 'rgba(37, 99, 235, 0.18)',
                borderColor: '#2563eb',
                pointBackgroundColor: '#0ea5e9'
            }]
        },
        options: commonOptions
    });

    new Chart(document.getElementById('graficoPolar'), {
        type: 'polarArea',
        data: { labels, datasets: [{ data: valores, backgroundColor: colores }] },
        options: commonOptions
    });
</script>
