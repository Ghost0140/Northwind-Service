@model NorthwindWebMvc.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - Northwind</title>

    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #0d6efd, #3a86ff, #4cc9f0);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-box {
            width: 100%;
            max-width: 420px;
            border-radius: 20px;
            animation: fadeIn 0.6s ease-in-out;
        }

        .login-title {
            font-weight: 600;
        }

        .input-group-text {
            background: #f1f3f5;
        }

        .form-control:focus {
            box-shadow: none;
            border-color: #0d6efd;
        }

        .btn-primary {
            border-radius: 10px;
            font-weight: 500;
        }

        .brand {
            font-size: 14px;
            color: #6c757d;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(15px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>

    <div class="card shadow-lg p-4 login-box">

        <!-- HEADER -->
        <div class="text-center mb-3">
            <i class="bi bi-database-fill text-primary" style="font-size: 2rem;"></i>
            <h3 class="login-title mt-2">Northwind</h3>
            <div class="brand">Sistema de Mantenimiento</div>
        </div>

        <!-- ERROR -->
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @ViewBag.Error
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- FORM -->
        <form asp-action="Login" method="post">

            <!-- USUARIO -->
            <div class="mb-3">
                <label asp-for="NombreUsuario" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-person"></i>
                    </span>
                    <input asp-for="NombreUsuario" class="form-control" placeholder="Ingrese usuario" />
                </div>
                <span asp-validation-for="NombreUsuario" class="text-danger"></span>
            </div>

            <!-- PASSWORD -->
            <div class="mb-3">
                <label asp-for="Clave" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="bi bi-lock"></i>
                    </span>
                    <input asp-for="Clave" class="form-control" type="password" id="password" placeholder="Ingrese contraseña" />
                    <button type="button" class="btn btn-outline-secondary" onclick="togglePassword()">
                        <i class="bi bi-eye" id="iconEye"></i>
                    </button>
                </div>
                <span asp-validation-for="Clave" class="text-danger"></span>
            </div>

            <!-- BOTÓN -->
            <button type="submit" class="btn btn-primary w-100 mt-2">
                <i class="bi bi-box-arrow-in-right"></i> Ingresar
            </button>

        </form>

        <!-- FOOTER -->
        <div class="text-center mt-3">
            <small class="text-muted">
                © @DateTime.Now.Year - Northwind CRUD
            </small>
        </div>

    </div>

    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword() {
            const input = document.getElementById("password");
            const icon = document.getElementById("iconEye");

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            }
        }
    </script>

</body>
</html>