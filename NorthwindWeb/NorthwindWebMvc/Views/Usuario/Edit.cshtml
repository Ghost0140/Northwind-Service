@model NorthwindWebMvc.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="crud-page">
    <div class="container">
        <div class="card crud-card">

            <!-- HEADER -->
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="bi bi-pencil-square"></i> Editar Usuario
                </h4>

                <a asp-action="Index"
                   class="btn btn-outline-light btn-sm btn-action">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
            </div>

            <!-- BODY -->
            <div class="card-body bg-white">

                <form asp-action="Edit" method="post" class="crud-form">
                    <input type="hidden" asp-for="IdUsuario" />

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Usuario</label>
                            <input asp-for="NombreUsuario" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Clave</label>
                            <input asp-for="Clave" class="form-control" type="password" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Rol</label>
                            <select asp-for="Rol" class="form-select">
                                <option value="Admin">Admin</option>
                                <option value="Usuario">Usuario</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3 d-flex align-items-center">
                            <div class="form-check mt-4">
                                <input asp-for="Estado" class="form-check-input" />
                                <label class="form-check-label">
                                    Activo
                                </label>
                            </div>
                        </div>

                    </div>

                    <!-- BOTONES -->
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-outline-warning btn-action">
                            <i class="bi bi-save"></i> Actualizar
                        </button>

                        <a asp-action="Index" class="btn btn-outline-secondary btn-action">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </a>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>