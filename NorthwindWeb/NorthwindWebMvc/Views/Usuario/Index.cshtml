@model IEnumerable<NorthwindWebMvc.Models.Usuario>

@{
    ViewData["Title"] = "Usuarios";
    int? adminProtegidoId = ViewBag.AdminProtegidoId as int?;
}

<div class="crud-page">
    <div class="container">
        <div class="card crud-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="bi bi-shield-lock"></i> Listado de Usuarios
                </h4>

                <div class="d-flex gap-2">
                    <a asp-controller="Home" asp-action="Index"
                           class="btn btn-outline-light btn-sm btn-action">
                        <i class="bi bi-house"></i> Inicio
                    </a>

                    <a asp-action="Create"
                           class="btn btn-outline-light btn-sm btn-action">
                        <i class="bi bi-plus-circle"></i> Nuevo
                    </a>
                </div>
            </div>

            <!-- MENSAJES -->
            @if (TempData["mensaje"] != null)
            {
                <div class="alert alert-info alert-dismissible fade show m-3">
                    <i class="bi bi-info-circle-fill"></i>
                    @TempData["mensaje"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show m-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @TempData["error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card-body bg-white">
                <div class="table-responsive">
                    <table class="table table-hover align-middle text-center crud-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Usuario</th>
                                <th>Rol</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-muted text-center py-4">
                                        No hay usuarios registrados.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.IdUsuario</td>
                                        <td>@item.NombreUsuario</td>
                                        <td>
                                            <span class="badge bg-primary">@item.Rol</span>
                                        </td>
                                        <td>
                                            @if (item.Estado)
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-circle"></i> Activo
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-x-circle"></i> Inactivo
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (Context.Session.GetString("rol") == "Admin")
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.IdUsuario"
                                                       class="btn btn-warning btn-sm"
                                                       title="Editar usuario">
                                                    <i class="bi bi-pencil"></i>
                                                </a>

                                                @if (!(adminProtegidoId.HasValue && item.IdUsuario == adminProtegidoId.Value))
                                                {
                                                    <a asp-action="Delete" asp-route-id="@item.IdUsuario"
                                                           class="btn btn-danger btn-sm"
                                                           onclick="return confirm('¿Desactivar usuario?')"
                                                           title="Desactivar usuario">
                                                        <i class="bi bi-toggle-off"></i>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="btn btn-secondary btn-sm disabled"
                                                          title="El primer usuario Admin creado no puede desactivarse">
                                                        <i class="bi bi-lock"></i>
                                                    </span>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>