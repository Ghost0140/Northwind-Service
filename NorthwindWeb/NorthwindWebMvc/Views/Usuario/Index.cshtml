@model IEnumerable<NorthwindWebMvc.Models.Usuario>

@{
    ViewData["Title"] = "Usuarios";
}

<div class="container mt-4">
    <div class="card shadow rounded-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Listado de Usuarios</h3>
            <a asp-action="Create" class="btn btn-light">Nuevo Usuario</a>
        </div>
        <div class="card-body">

            @if (TempData["mensaje"] != null)
            {
                <div class="alert alert-success">@TempData["mensaje"]</div>
            }

            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Usuario</th>
                        <th>Clave</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.IdUsuario</td>
                            <td>@item.NombreUsuario</td>
                            <td>@item.Clave</td>
                            <td>@item.Rol</td>
                            <td>@(item.Estado ? "Activo" : "Inactivo")</td>
                            <td>
                                @if (Context.Session.GetString("rol") == "Admin")
                                {
                                    <a asp-action="Edit" asp-route-id="@item.IdUsuario"
                                       class="btn btn-warning btn-sm">
                                        ✏️
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.IdUsuario"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('¿Eliminar usuario?')">
                                        🗑️
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>